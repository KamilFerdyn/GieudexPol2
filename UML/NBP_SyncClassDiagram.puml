@startuml
title Diagram klas - pobieranie kursow z NBP

skinparam classAttributeIconSize 0
hide empty members

package "Frontend Angular" {
    class ExchangeRateDashboard <<component>> {
        - currency: string
        - source: string
        - from: string
        - to: string
        - chartPoints: ExchangeRateChartPoint[]
        - latestRates: ExchangeRateTableRow[]
        - loading: boolean
        - syncingNbp: boolean
        + fetchData(): Promise<void>
        + onSourceChange(source: string): void
        - fetchDataWithOptionalNbpSync(): Promise<void>
        - runNbpSync(): Promise<boolean>
        - loadDataFromBackend(): Promise<void>
    }

    class ExchangeRateApiService <<service>> {
        - apiUrl: string
        + getChartData(currency: string, source: string, from: string, to: string)
        + getLatestRates(source: string)
        + syncNbpRates(from: string, to: string)
    }
}

package "API" {
    class ExchangeRatesController <<controller>> {
        - _exchangeRateService: IExchangeRateService
        - _exchangeRateSyncService: IExchangeRateSyncService
        + GetChartData(currency: string, source: string, from: DateTime, to: DateTime)
        + GetLatestRates(source: string)
        + SyncNbpRates(from: DateTime, to: DateTime, cancellationToken: CancellationToken)
    }
}

package "Application.Interfaces" {
    interface IExchangeRateService {
        + GetChartDataAsync(currencyCode: string, sourceCode: string, from: DateTime, to: DateTime)
        + GetLatestRatesAsync(sourceCode: string)
    }

    interface IExchangeRateSyncService {
        + SyncNbpRatesAsync(from: DateTime, to: DateTime, cancellationToken: CancellationToken)
    }

    interface INbpExchangeRateClient {
        + GetTableCRatesAsync(from: DateTime, to: DateTime, cancellationToken: CancellationToken)
    }

    interface IExchangeRateRepository {
        + GetChartDataAsync(currencyCode: string, sourceCode: string, from: DateTime, to: DateTime)
        + GetLatestRatesAsync(sourceCode: string)
        + ExistsAsync(currencyId: int, rateSourceId: int, effectiveDate: DateTime)
    }

    interface IRateSourceRepository {
        + GetByCodeAsync(code: string)
    }
}

package "Application.Services" {
    class ExchangeRateService <<service>> {
        - _exchangeRateRepository: IExchangeRateRepository
        + GetChartDataAsync(currencyCode: string, sourceCode: string, from: DateTime, to: DateTime)
        + GetLatestRatesAsync(sourceCode: string)
    }
}

package "Infrastructure.Services" {
    class ExchangeRateSyncService <<service>> {
        - MaxNbpRangeDays: int = 93
        - NbpSourceCode: string = "NBP"
        - NbpSourceName: string = "Narodowy Bank Polski"
        - _context: ApplicationDbContext
        - _nbpClient: INbpExchangeRateClient
        + SyncNbpRatesAsync(from: DateTime, to: DateTime, cancellationToken: CancellationToken)
        - GetOrCreateNbpRateSourceAsync(cancellationToken: CancellationToken)
        - GetExistingRateKeysAsync(rateSourceId: int, from: DateTime, to: DateTime, cancellationToken: CancellationToken)
        - SplitIntoNbpRanges(from: DateTime, to: DateTime)
    }
}

package "Infrastructure.ExternalServices.Nbp" {
    class NbpExchangeRateClient <<http client>> {
        - _httpClient: HttpClient
        + GetTableCRatesAsync(from: DateTime, to: DateTime, cancellationToken: CancellationToken)
    }
}

package "Infrastructure" {
    class ApplicationDbContext <<DbContext>> {
        + Currencies: DbSet<Currency>
        + RateSources: DbSet<RateSource>
        + ExchangeRates: DbSet<ExchangeRate>
        # OnModelCreating(modelBuilder: ModelBuilder): void
    }
}

package "Domain.Entities" {
    class Currency {
        + Id: int
        + Symbol: string
        + Name: string
        + IsActive: bool
        + ExchangeRates: ICollection<ExchangeRate>
    }

    class RateSource {
        + Id: int
        + Code: string
        + Name: string
        + IsActive: bool
        + ExchangeRates: ICollection<ExchangeRate>
    }

    class ExchangeRate {
        + Id: int
        + CurrencyId: int
        + Currency: Currency
        + RateSourceId: int
        + RateSource: RateSource
        + BuyPrice: decimal
        + SellPrice: decimal
        + EffectiveDate: DateTime
        + FetchedAt: DateTime
    }
}

package "Application.DTOs" {
    class NbpExchangeRateTableDto {
        + Table: string
        + No: string
        + EffectiveDate: DateTime
        + Rates: List<NbpExchangeRateItemDto>
    }

    class NbpExchangeRateItemDto {
        + Currency: string
        + Code: string
        + Bid: decimal
        + Ask: decimal
    }

    class NbpSyncResultDto {
        + From: DateTime
        + To: DateTime
        + Added: int
        + Skipped: int
        + TablesFetched: int
        + ProcessedRanges: List<string>
        + Warnings: List<string>
    }

    class ExchangeRateChartResponseDto {
        + CurrencyCode: string
        + SourceCode: string
        + From: DateTime
        + To: DateTime
        + Points: List<ExchangeRateChartPointDto>
    }

    class ExchangeRateChartPointDto {
        + Date: DateTime
        + BuyPrice: decimal
        + SellPrice: decimal
    }

    class ExchangeRateTableRowDto {
        + CurrencyCode: string
        + CurrencyName: string
        + SourceCode: string
        + SourceName: string
        + EffectiveDate: DateTime
        + BuyPrice: decimal
        + SellPrice: decimal
    }
}

ExchangeRateDashboard --> ExchangeRateApiService : uses
ExchangeRateApiService --> ExchangeRatesController : HTTP

ExchangeRatesController --> IExchangeRateService : reads data
ExchangeRatesController --> IExchangeRateSyncService : starts sync

IExchangeRateService <|.. ExchangeRateService
IExchangeRateSyncService <|.. ExchangeRateSyncService
INbpExchangeRateClient <|.. NbpExchangeRateClient

ExchangeRateService --> IExchangeRateRepository
ExchangeRateSyncService --> ApplicationDbContext
ExchangeRateSyncService --> INbpExchangeRateClient
NbpExchangeRateClient --> NbpExchangeRateTableDto
NbpExchangeRateTableDto "1" *-- "many" NbpExchangeRateItemDto

ApplicationDbContext --> Currency
ApplicationDbContext --> RateSource
ApplicationDbContext --> ExchangeRate

Currency "1" -- "many" ExchangeRate
RateSource "1" -- "many" ExchangeRate

ExchangeRateSyncService --> NbpSyncResultDto
ExchangeRateService --> ExchangeRateChartResponseDto
ExchangeRateService --> ExchangeRateTableRowDto
ExchangeRateChartResponseDto "1" *-- "many" ExchangeRateChartPointDto

note right of ExchangeRate
Unikalnosc w bazie:
CurrencyId + RateSourceId + EffectiveDate
end note

note bottom of ExchangeRateSyncService
Zakres NBP jest dzielony
na paczki po maksymalnie 93 dni.
end note

@enduml
