@startuml
title Synchronizacja kursow walut z NBP

actor "Uzytkownik" as User
participant "ExchangeRateDashboard\nAngular /rates" as Frontend
participant "ExchangeRateApiService" as FrontendApi
participant "ExchangeRatesController" as Controller
participant "ExchangeRateService" as ReadService
participant "ExchangeRateSyncService" as SyncService
participant "NbpExchangeRateClient" as NbpClient
database "ApplicationDbContext\nBaza danych" as Db
participant "NBP API\nTabela C" as NbpApi

User -> Frontend: wybiera zrodlo NBP
activate Frontend

Frontend -> FrontendApi: getChartData(currency, "NBP", from, to)
activate FrontendApi
FrontendApi -> Controller: GET /api/ExchangeRates/chart
activate Controller
Controller -> ReadService: GetChartDataAsync(currency, "NBP", from, to)
activate ReadService
ReadService -> Db: odczytaj lokalne kursy NBP
activate Db
Db --> ReadService: punkty wykresu albo pusta lista
deactivate Db
ReadService --> Controller: ExchangeRateChartResponseDto
deactivate ReadService
Controller --> FrontendApi: 200 OK
deactivate Controller
FrontendApi --> Frontend: response.points
deactivate FrontendApi

alt lokalne dane istnieja
    Frontend -> Frontend: wyswietl wykres i tabele
else brak lokalnych danych dla zakresu
    Frontend -> Frontend: pokaz status synchronizacji NBP
    Frontend -> FrontendApi: syncNbpRates(from, to)
    activate FrontendApi
    FrontendApi -> Controller: POST /api/ExchangeRates/sync/nbp?from&to
    activate Controller

    alt from > to lub from < 2026-01-01 lub to > dzisiaj
        Controller --> FrontendApi: 400 Bad Request
        FrontendApi --> Frontend: blad walidacji
        Frontend -> Frontend: pokaz komunikat bledu
    else zakres poprawny
        Controller -> SyncService: SyncNbpRatesAsync(from, to)
        activate SyncService
        SyncService -> Db: znajdz lub utworz RateSource "NBP"
        activate Db
        Db --> SyncService: RateSource
        deactivate Db

        SyncService -> Db: pobierz waluty i istniejace kursy z zakresu
        activate Db
        Db --> SyncService: Currency[], klucze istniejacych ExchangeRate
        deactivate Db

        loop zakresy po maksymalnie 93 dni
            SyncService -> NbpClient: GetTableCRatesAsync(rangeFrom, rangeTo)
            activate NbpClient
            NbpClient -> NbpApi: GET /api/exchangerates/tables/C/{from}/{to}/?format=json
            activate NbpApi

            alt NBP zwraca 404
                NbpApi --> NbpClient: 404 brak danych
                deactivate NbpApi
                NbpClient --> SyncService: pusta lista
            else NBP zwraca tabele C
                NbpApi --> NbpClient: JSON table C z bid/ask
                deactivate NbpApi
                NbpClient --> SyncService: NbpExchangeRateTableDto[]
            end
            deactivate NbpClient

            loop kazda tabela i kazda waluta
                alt waluta nie istnieje
                    SyncService -> Db: dodaj Currency(code, currency)
                end

                alt kurs juz istnieje dla Currency + NBP + EffectiveDate
                    SyncService -> SyncService: Skipped++
                else nowy kurs
                    SyncService -> Db: dodaj ExchangeRate(bid, ask, EffectiveDate, FetchedAt)
                    SyncService -> SyncService: Added++
                end
            end
        end

        SyncService -> Db: SaveChangesAsync()
        activate Db
        Db --> SyncService: zapisano zmiany
        deactivate Db
        SyncService --> Controller: NbpSyncResultDto
        deactivate SyncService
        Controller --> FrontendApi: 200 OK
        FrontendApi --> Frontend: wynik synchronizacji

        Frontend -> FrontendApi: getChartData(currency, "NBP", from, to)
        FrontendApi -> Controller: GET /api/ExchangeRates/chart
        Controller -> ReadService: GetChartDataAsync(...)
        ReadService -> Db: odczytaj zapisane kursy NBP
        Db --> ReadService: punkty wykresu
        ReadService --> Controller: ExchangeRateChartResponseDto
        Controller --> FrontendApi: 200 OK
        FrontendApi --> Frontend: response.points

        Frontend -> FrontendApi: getLatestRates("NBP")
        FrontendApi -> Controller: GET /api/ExchangeRates/latest
        Controller -> ReadService: GetLatestRatesAsync("NBP")
        ReadService -> Db: pobierz najnowszy kurs dla kazdej waluty
        Db --> ReadService: ExchangeRateTableRowDto[]
        ReadService --> Controller: DTO[]
        Controller --> FrontendApi: 200 OK
        FrontendApi --> Frontend: latest rates

        Frontend -> Frontend: wyswietl wykres i tabele
    end
    deactivate Controller
    deactivate FrontendApi
end

deactivate Frontend
@enduml
